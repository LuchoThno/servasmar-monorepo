# API
API_ORIGIN=https://your-api.example.com

# MongoDB for Clerk webhook sync
MONGODB_URI=mongodb+srv://your-cluster.example.com/servasmar
MONGODB_DB=servasmar

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk_live_publishable_key
CLERK_SECRET_KEY=clerk_live_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin
CLERK_AUTHORIZED_PARTIES=https://your-domain.example.com,https://www.your-domain.example.com
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
CLERK_WEBHOOK_SECRET=clerk_webhook_signing_secret
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWKS_URI=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_API_URL=https://api.clerk.com

# Google Calendar / Google Meet
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_CALENDAR_ID=primary # or 95d0f9658fb10720a040e32f72f1670586f3c20d26feb66e2f9f7c7bf31a810d@group.calendar.google.com, not an iCal URL
GOOGLE_REDIRECT_URI=http://localhost

# Resend
RESEND_API_KEY=resend_api_key
RESEND_FROM_EMAIL="SERVASMAR <contacto@tu-dominio.cl>"
MAIL_FROM="SERVASMAR <contacto@tu-dominio.cl>"
CONTACT_EMAIL=contacto@tu-dominio.cl
NEXT_PUBLIC_CONTACT_EMAIL=contacto@tu-dominio.cl
